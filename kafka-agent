#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
NATIVE_BIN="$SCRIPT_DIR/build/native/nativeCompile/kafka-agent"
JAR="$SCRIPT_DIR/build/libs/kafka-agent.jar"

# Prefer native binary if it exists
if [ -x "$NATIVE_BIN" ]; then
    exec "$NATIVE_BIN" "$@"
fi

# Find java: SDKMAN > JAVA_HOME > PATH
if [ -x "${SDKMAN_DIR:-$HOME/.sdkman}/candidates/java/current/bin/java" ]; then
    JAVA="${SDKMAN_DIR:-$HOME/.sdkman}/candidates/java/current/bin/java"
elif [ -n "${JAVA_HOME:-}" ] && [ -x "$JAVA_HOME/bin/java" ]; then
    JAVA="$JAVA_HOME/bin/java"
else
    JAVA="$(command -v java 2>/dev/null || true)"
    if [ -z "$JAVA" ]; then
        echo "ERROR: Java not found. Install Java 21+ or set JAVA_HOME." >&2
        exit 1
    fi
fi

if [ ! -f "$JAR" ]; then
    echo "Fat JAR not found. Building..."
    "$SCRIPT_DIR/gradlew" -q shadowJar
fi

exec "$JAVA" --enable-native-access=ALL-UNNAMED -jar "$JAR" "$@"
